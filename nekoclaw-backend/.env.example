# App
DEBUG=true

# Database（PostgreSQL）
DATABASE_URL=postgresql+asyncpg://nekoclaw:nekoclaw@localhost:5432/nekoclaw
DATABASE_NAME_SUFFIX=

# CE 超管
INIT_ADMIN_ACCOUNT=admin
RESET_ADMIN_PASSWORD=false

# JWT
JWT_SECRET=change-me-in-production
JWT_EXPIRE_HOURS=24

# KubeConfig 加密密钥（32 字节 base64）
ENCRYPTION_KEY=change-me-32-bytes-base64-key__=

# OAuth SSO（可选）
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_REDIRECT_URI=http://localhost:4517/login/callback/feishu
