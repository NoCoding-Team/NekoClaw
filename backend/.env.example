# ============================================================
# NekoClaw 后端环境配置示例
# 复制为 .env 并填写真实值后启动后端
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/nekoclaw

# ── Milvus 向量数据库 ──────────────────────────────────────────
# 用于记忆语义检索，不填则退化为纯 BM25 关键词检索
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=memory_vectors

# ── 认证 ──────────────────────────────────────────────────────
# JWT 签名密钥（生产环境请替换为足够长的随机字符串）
JWT_SECRET=change-me-use-a-long-random-string
JWT_EXPIRE_HOURS=24

# ── 加密 ──────────────────────────────────────────────────────
# LLM API Key 的加密密钥（32 字节 base64，可用 openssl rand -base64 32 生成）
ENCRYPTION_KEY=change-me-32-bytes-base64-key=====

# ── 后端行为 ───────────────────────────────────────────────────
DEBUG=false
INIT_ADMIN_ACCOUNT=admin
RESET_ADMIN_PASSWORD=false
# 是否记录 LLM 请求响应内容到数据库（调试用，生产建议 false）
LLM_LOG_CONTENT=false

# ── Embedding 模型（用于记忆向量化，可选）────────────────────────
# 不填则向量搜索不生效，仅使用 BM25
EMBEDDING_BASE_URL=https://api.openai.com/v1
EMBEDDING_MODEL=text-embedding-3-small
EMBEDDING_API_KEY=

# ── CORS ──────────────────────────────────────────────────────
# 桌面 Electron 应用从 file:// 加载时 Origin 为 null，* 放行所有来源
# 生产环境可设置为具体域名，如 https://yourdomain.com
CORS_ORIGINS=*

# ── 可选：HTTPS 代理（访问 OpenAI / Anthropic 等）─────────────
# HTTPS_PROXY=http://your-proxy:7890

# ── 可选：OAuth SSO（飞书）────────────────────────────────────
# FEISHU_APP_ID=
# FEISHU_APP_SECRET=
# FEISHU_REDIRECT_URI=http://your-server/login/callback/feishu
