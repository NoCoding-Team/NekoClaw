# ============================================================
# NekoClaw 环境配置示例
# 复制此文件为 .env 并填写实际值
# ============================================================

# ── PostgreSQL ────────────────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/nekoclaw

# ── Milvus 向量数据库（可选，不填则禁用向量搜索）─────────────────
MILVUS_URI=http://localhost:19530
MILVUS_COLLECTION=memory_vectors

# ── 后端鉴权 ──────────────────────────────────────────────────
# SECRET_KEY: 随机字符串，用于 JWT 签名，生成命令：openssl rand -hex 32
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
REFRESH_TOKEN_EXPIRE_DAYS=30
# LLM_API_KEY_ENCRYPTION_KEY: 32字节 base64，生成命令：openssl rand -base64 32
LLM_API_KEY_ENCRYPTION_KEY=your-encryption-key-here

# ── 跨域 ──────────────────────────────────────────────────────
# 多个地址用逗号分隔，Electron 客户端需加 app://nekoclaw
CORS_ORIGINS=http://localhost:5173,http://localhost:3001,app://nekoclaw

# ── 外部工具 ──────────────────────────────────────────────────
# Tavily 搜索 API Key（可选，不填则禁用网络搜索）
TAVILY_API_KEY=

# ── 初始管理员账号 ────────────────────────────────────────────
# 首次启动时自动创建，已存在则跳过（不会覆盖密码）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=your-admin-password
